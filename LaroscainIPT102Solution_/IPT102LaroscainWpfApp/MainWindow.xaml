<Window x:Class="IPT102LaroscainWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laroscain Desktop Admin" Height="450" Width="700"
        WindowStartupLocation="CenterScreen" Background="#F4F4F4">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Employee Details" Grid.Row="0" Margin="0,0,0,10" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtName" Width="150" Margin="5" Tag="Name" ToolTip="Name"/>
                <TextBox x:Name="txtPosition" Width="120" Margin="5" Tag="Position" ToolTip="Position"/>
                <TextBox x:Name="txtSalary" Width="100" Margin="5" Tag="Salary" ToolTip="Salary"/>
                <Button Content="Add Record" Click="OnAddClick" Background="#28a745" Foreground="White" Width="100" Margin="10,5"/>
            </StackPanel>
        </GroupBox>

        <DataGrid Grid.Row="1" x:Name="dgEmployees" AutoGenerateColumns="False" 
                  CanUserAddRows="False" SelectionMode="Single" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Full Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="*"/>
                <DataGridTextColumn Header="Salary" Binding="{Binding Salary, StringFormat=N2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Refresh" Click="OnRefreshClick" Width="80" Margin="5"/>
            <Button Content="Exit" Click="OnExitClick" Width="80" Margin="5" Background="#dc3545" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>